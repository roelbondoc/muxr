#!/usr/bin/env ruby
# frozen_string_literal: true

$LOAD_PATH.unshift(File.expand_path("../lib", __dir__))
require "rux"

if ARGV.include?("-v") || ARGV.include?("--version")
  puts "rux #{Rux::VERSION}"
  exit 0
end

if ARGV.include?("-l") || ARGV.include?("--list")
  names = Rux::Session.list
  puts names.join("\n") unless names.empty?
  exit 0
end

if ARGV.include?("-h") || ARGV.include?("--help")
  puts <<~USAGE
    rux #{Rux::VERSION} — a tiling terminal multiplexer

    Usage:
      rux                 start the default session
      rux <name>          start (or restore) the named session
      rux -s <name>       same as above
      rux --list          list saved sessions and exit
      rux --version       print version and exit
      rux --help          this help

    Keybindings (Ctrl-a prefix):
      C-a c   new pane            C-a n / p   next / prev pane
      C-a k   close pane          C-a Tab     cycle layout
      C-a ~   toggle drawer       C-a Enter   promote to master
      C-a :   command prompt      C-a ?       toggle help
      C-a d   detach              C-a C-a     send literal C-a
  USAGE
  exit 0
end

Rux::Application.new(ARGV).run
